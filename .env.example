# ── Required ──
# Generate with: openssl rand -hex 32
CREDS_KEY=your-32-byte-hex-key
CREDS_IV=your-16-byte-hex-key
JWT_SECRET=your-jwt-secret

# MongoDB
MONGO_URI=mongodb://mongodb:27017/LibreChat

# ── GREA Stack ──

# Twenty CRM
TWENTY_CRM_API_KEY=eyJ...
TWENTY_CRM_BASE_URL=https://api.twenty.com

# OpenConnector (1,000+ SaaS connectors)
OOMOL_ENCRYPTION_KEY=your-32-char-key-here-change-me
OOMOL_ADMIN_TOKEN=your-admin-token-change-me

# OpenCode Go (primary AI provider)
OPENCODE_GO_API_KEY=your_key_here

# Optional: OmniRoute self-hosted
# OMNIROUTE_URL=http://localhost:4000/v1

# ── LibreChat Defaults ──

# Domain
DOMAIN=localhost:3080
ALLOWED_DOMAINS=

# Search
SEARCH=true
TAVILY_API_KEY=
MEILI_SEARCH_HOST=http://rag:7700
MEILI_MASTER_KEY=your-meili-key

# File handling
FILE_FORMATS_ALLOWED=pdf,txt,doc,docx,csv,json,yaml,yml,md,html,xlsx,zip,png,jpg,jpeg,gif
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OPENAI_API_KEY=

# Host config
HOST=0.0.0.0
PORT=3080
